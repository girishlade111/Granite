{
  "name": "granite",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first Markdown knowledge management application",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:portable": "npm run build:renderer && electron-builder --win portable",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.17.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/markdown": "^1.3.0",
    "@tanstack/react-virtual": "^3.0.0",
    "chokidar": "^4.0.0",
    "codemirror": "^6.0.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-remark": "^10.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
  "appId": "com.granite.app",
  "productName": "Granite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": ["nsis", "portable"],
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "icon": "assets",
      "target": ["AppImage", "deb"]
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown file",
        "mimeType": "text/markdown"
      },
      {
        "ext": "canvas",
        "name": "Granite Canvas",
        "description": "Granite canvas file",
        "mimeType": "application/json"
      }
    ],
    "protocols": {
      "name": "Granite",
      "schemes": ["granite"]
    }
  }
}
